/* 1. Import the CSV generated by R into a temporary SAS dataset */
proc import datafile="/home/sas/44a001478710899/sasdata/sasdata1/allowed_nirs.csv"
    out=work.allowed_nirs
    dbms=csv
    replace;
    getnames=yes;
run;

/* 2. Macro to loop through years 15 to 20 for BOTH RIP and MCO tables */
%macro extract_all_data;
    proc sql;
    %do year = 15 %to 20;
        
        /* --- Extract RIP Data --- */
        create table work.rip_extract_20&year. as 
        select 
            main.NIR_ANO_17, 
            main.EXE_SOI_DTD, 
            main.EXE_SOI_DTF
        from 
            oravue.T_RIP&year.C as main
        inner join 
            work.allowed_nirs as filter
        on 
            main.NIR_ANO_17 = filter.NIR_ANO_17;
            
        /* --- Extract MCO Data --- */
        create table work.mco_extract_20&year. as 
        select 
            main.NIR_ANO_17, 
            main.EXE_SOI_DTD, 
            main.EXE_SOI_DTF
        from 
            oravue.T_MCO&year.C as main   /* Note the underscore structure: T_MCOxxC */
        inner join 
            work.allowed_nirs as filter
        on 
            main.NIR_ANO_17 = filter.NIR_ANO_17

        WHERE main.NIR_ANO_17   not in ('xxxxxxxxxxxxxxxxx', 'BXXXXXXXXXXXXXXXX') 
	            and (NIR_RET = '0' and NAI_RET = '0' and SEX_RET = '0' and SEJ_RET = '0' 
	            and FHO_RET = '0'  and PMS_RET = '0' and DAT_RET = '0');             
    %end;
    quit;
%mend extract_all_data;

/* 3. Execute the loop */
%extract_all_data;
