/* 1. Import the CSV generated by R into a temporary SAS dataset */
proc import datafile="C:/your_shared_folder/allowed_nirs.csv"
    out=work.allowed_nirs
    dbms=csv
    replace;
    getnames=yes;
run;

/* 2. Create the macro to loop through the years 15 to 19 */
%macro extract_rip_data;
    proc sql;
    %do year = 15 %to 19;
        
        create table work.rip_extract_20&year. as 
        select 
            main.NIR_ANO_17, 
            main.EXE_SOI_DTD, 
            main.EXE_SOI_DTF
        from 
            oravue.T_RIP&year.C as main
        inner join 
            work.allowed_nirs as filter
        on 
            main.NIR_ANO_17 = filter.NIR_ANO_17;
            
    %end;
    quit;
%mend extract_rip_data;

/* 3. Execute the loop */
%extract_rip_data;
